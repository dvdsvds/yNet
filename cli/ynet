HTMLEOF

    cat > "$name/.gitignore" << 'GITEOF'
build/
compile_commands.json
GITEOF

    echo ""
    echo "  Project '$name' created!"
    echo ""
    echo "  cd $name"
    echo "  ynet build"
    echo "  ynet run"
    echo ""
}

cmd_build() {
    if [ ! -f "CMakeLists.txt" ]; then
        echo "Error: not a yNet project (CMakeLists.txt not found)"
        exit 1
    fi

    mkdir -p build
    cmake -S . -B build && make -C build -j$(nproc)

    if [ $? -eq 0 ]; then
        echo ""
        echo "Build successful!"
    fi
}

cmd_run() {
    if [ ! -f "CMakeLists.txt" ]; then
        echo "Error: not a yNet project (CMakeLists.txt not found)"
        exit 1
    fi

    local name
    name=$(grep "^project(" CMakeLists.txt | sed 's/project(\([^ )]*\).*/\1/')

    if [ ! -f "build/$name" ]; then
        echo "Binary not found. Building first..."
        cmd_build
    fi

    echo "Starting $name..."
    ./build/"$name"
}

cmd_clean() {
    if [ -d "build" ]; then
        rm -rf build
        echo "Build files cleaned."
    else
        echo "Nothing to clean."
    fi
}

case "${1}" in
    new)    cmd_new "$2" ;;
    build)  cmd_build ;;
    run)    cmd_run ;;
    clean)  cmd_clean ;;
    help)   usage ;;
    *)      usage ;;
esac
